# ─────────────────────────────────────────────────────────────────────────────
# VideoAgent — Environment Variable Reference
#
# Copy this file to .env and edit the values for your environment.
# Linux defaults (Vast.ai /workspace) are pre-filled.
# Windows users: override with local paths (use forward slashes or raw strings).
#
# DO NOT commit .env — it is in .gitignore.
# DO commit .env.example — it is the canonical reference.
# ─────────────────────────────────────────────────────────────────────────────


# ── Server ────────────────────────────────────────────────────────────────────

# Port Flask listens on
VIDEO_AGENT_PORT=5100


# ── LLM / LM Studio ───────────────────────────────────────────────────────────

# Base URL of the LM Studio REST API (OpenAI-compatible)
# Windows: http://localhost:1234  (LM Studio runs on host)
# Vast.ai:  http://localhost:1234  (if running LM Studio in the same instance)
LM_STUDIO_URL=http://localhost:1234

# Force a specific model ID for the LLM planner (skips auto-detection)
# Leave blank to auto-detect from /v1/models (recommended)
# Example: LLM_PLANNER_MODEL=qwen2.5-7b-instruct-1m
LLM_PLANNER_MODEL=

# Set to 0 to disable the LLM narrative-reorder pass entirely
ENABLE_LLM_PLANNER=1


# ── Vision tagger (Moondream) ─────────────────────────────────────────────────

# Enable Moondream2 vision tagging: set to "moondream", else leave as "none"
VISION_TAGGER_MODEL=none

# Override path to the Moondream GGUF model directory
# Default: auto-resolved from LM Studio model cache
# Windows example: MOONDREAM_MODEL_DIR=C:\Users\you\.lmstudio\models\moondream
MOONDREAM_MODEL_DIR=


# ── External AI tools — paths ─────────────────────────────────────────────────
# Linux defaults point to /workspace (Vast.ai standard layout).
# Windows: set these in your .env to your local install locations.

# ProPainter (fallback inpainter — pixel propagation)
# Windows example: PROPAINTER_DIR=D:\video-agent\ProPainter
PROPAINTER_DIR=/workspace/ProPainter

# E2FGVI (temporal consistency pass after LaMa)
# Windows example: E2FGVI_DIR=D:\video-agent\E2FGVI
E2FGVI_DIR=/workspace/E2FGVI

# DiffuEraser (generative inpainter — replaces LaMa+E2FGVI stack)
# Windows example: DIFFUERASER_DIR=D:\video-agent\DiffuEraser
DIFFUERASER_DIR=/workspace/DiffuEraser

# DiffuEraser weights directory (default: DIFFUERASER_DIR/weights)
# Override only if weights are stored separately from the repo clone.
DIFFUERASER_WEIGHTS=

# Stable Diffusion v1.5 (backbone for DiffuEraser)
# Windows example: STABLE_DIFFUSION_DIR=D:\video-agent\stable-diffusion-v1-5
STABLE_DIFFUSION_DIR=/workspace/stable-diffusion-v1-5

# SAM2 checkpoint directory (contains sam2_hiera_large.pt)
# Windows example: SAM2_CHECKPOINTS_DIR=D:\video-agent\sam2_checkpoints
SAM2_CHECKPOINTS_DIR=/workspace/sam2_checkpoints

# Full path override for a single SAM2 checkpoint file
# Default: SAM2_CHECKPOINTS_DIR/sam2_hiera_large.pt
SAM2_CHECKPOINT=

# SAM2 Hydra model config name (must match the checkpoint)
# Default: configs/sam2/sam2_hiera_large  (relative to sam2 package root)
# Override only if using a different checkpoint variant (e.g. configs/sam2/sam2_hiera_t)
SAM2_MODEL_CFG=configs/sam2/sam2_hiera_large

# DiffuEraser resolution — max short-side px before OOM fallback
DIFFUERASER_MAX_SIZE=960
# Short-side px used on OOM retry
DIFFUERASER_FALLBACK_SIZE=640

# SAM ViT-B checkpoint (original SAM, used by sam_helper.py)
# Default: <repo_root>/style/sam_vit_b.pth (auto-downloaded on first use)
# Override only if you want the file stored elsewhere.
SAM_CHECKPOINT=

# SAM inference device: "cuda", "cpu", or leave blank for auto-detect
SAM_DEVICE=


# ── Inpainting ────────────────────────────────────────────────────────────────

# Maximum short-side resolution for LaMa frame extraction (pixels)
LAMA_MAX_RESOLUTION=1080

# E2FGVI sliding-window inference parameters
E2FGVI_NEIGHBOR_LEN=10
E2FGVI_REF_STRIDE=10

# Google Drive sync root for remote ProPainter Colab jobs
# Default: <repo_root>/output/inpainted
# Example: DRIVE_SYNC_DIR=/mnt/gdrive/VideoAgent/inpainted
DRIVE_SYNC_DIR=


# ── Pipeline ──────────────────────────────────────────────────────────────────

# Style template to apply (must match a filename in style_profiles/)
STYLE_TEMPLATE=travel_reel

# Number of buffer segments kept as alternates during selection
BUFFER_SEGMENTS=5

# Parallel workers for clip analysis (lower on machines with less RAM)
MAX_ANALYSIS_WORKERS=4

# Set to 1 to force re-analysis of all clips (ignores cache)
DISABLE_CACHE=0

# Set to 1 to enable Whisper speech analysis (requires whisper installed)
ENABLE_SPEECH_ANALYSIS=0


# ── Rendering ─────────────────────────────────────────────────────────────────

# Render quality profile: "proxy" | "high" | "4k" (leave blank for default)
RENDER_QUALITY=

# Manual render dimensions in pixels (0 = auto from template)
RENDER_WIDTH=0
RENDER_HEIGHT=0


# ── SigLIP / aesthetics ───────────────────────────────────────────────────────

# Batch size for SigLIP GPU encoding (reduce if OOM)
SIGLIP_BATCH_SIZE=16

# Skip motion-smoothness analysis for clips shorter than this (seconds)
MOTION_SMOOTHNESS_MIN_DURATION=3.0


# ── Color grading ─────────────────────────────────────────────────────────────

# Use FP16 for color grading (set to 0 if you see NaN errors on CPU)
COLOR_GRADE_FP16=1

# Rows processed per chunk during color grading (reduce if OOM)
COLOR_GRADE_CHUNK_ROWS=240
